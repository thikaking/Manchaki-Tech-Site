# Supabase Configuration
# Copy this file to .env and fill in your Supabase project details
# Get these values from your Supabase project dashboard -> Settings -> API

# Supabase Project URL (e.g., https://abc123.supabase.co)
VITE_SUPABASE_URL=your_supabase_project_url_here

# Supabase Anon / Public Key (safe for frontend use)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# IMPORTANT SECURITY NOTES:
# - Never commit the .env file to version control
# - Never expose the service_role key in frontend code
# - The anon key is safe for frontend use as long as RLS is enabled